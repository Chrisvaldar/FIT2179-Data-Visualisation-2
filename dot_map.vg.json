{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Every Shark Incident in Australia, 1791–2022",
    "subtitle": "1,196 incidents plotted by location. Colour indicates outcome.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "width": 700,
  "height": 700,
  "params": [
    {
      "name": "decade_select",
      "value": null,
      "bind": {
        "input": "select",
        "options": [
          null,
          1790,
          1800,
          1810,
          1820,
          1830,
          1840,
          1850,
          1860,
          1870,
          1880,
          1890,
          1900,
          1910,
          1920,
          1930,
          1940,
          1950,
          1960,
          1970,
          1980,
          1990,
          2000,
          2010,
          2020
        ],
        "labels": [
          "All decades",
          "1790s",
          "1800s",
          "1810s",
          "1820s",
          "1830s",
          "1840s",
          "1850s",
          "1860s",
          "1870s",
          "1880s",
          "1890s",
          "1900s",
          "1910s",
          "1920s",
          "1930s",
          "1940s",
          "1950s",
          "1960s",
          "1970s",
          "1980s",
          "1990s",
          "2000s",
          "2010s",
          "2020s"
        ],
        "name": "Filter by decade: "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": [133, -27],
    "scale": 850
  },
  "layer": [
    {
      "data": {
        "url": "data/topojson/australia.json",
        "format": {
          "type": "topojson",
          "feature": "australia"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "green",
        "stroke": "#b0a898",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "data/wrangled_data/dot_map.csv"
      },
      "transform": [
        { "filter": "decade_select === null || datum.Decade == decade_select" }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.7,
        "filled": true,
        "stroke": "white",
        "strokeWidth": 0.3
      },
      "encoding": {
        "longitude": { "field": "Longitude", "type": "quantitative" },
        "latitude": { "field": "Latitude", "type": "quantitative" },
        "color": {
          "field": "Victim\\.injury",
          "type": "nominal",
          "scale": {
            "domain": ["fatal", "injured", "uninjured"],
            "range": ["#c0392b", "#e67e22", "#7f8c8d"]
          },
          "legend": {
            "title": "Outcome",
            "orient": "bottom-left",
            "labelFontSize": 11
          }
        },
        "size": { "value": 40 },
        "tooltip": [
          { "field": "Incident\\.year", "title": "Year" },
          { "field": "Location", "title": "Location" },
          { "field": "Species\\.clean", "title": "Shark" },
          { "field": "Activity\\.clean", "title": "Activity" },
          { "field": "Victim\\.injury", "title": "Outcome" },
          { "field": "Provoked\\.unprovoked", "title": "Provoked?" },
          { "field": "State", "title": "State" }
        ]
      }
    }
  ]
}
