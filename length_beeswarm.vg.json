{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1000,
  "height": 340,
  "padding": { "top": 28, "left": 8, "right": 12, "bottom": 12 },
  "data": { "url": "data/wrangled_data/length_beeswarm.csv" },
  "config": {
    "view": { "stroke": "transparent", "clip": true },
    "axis": { "labelFont": "Source Sans 3", "titleFont": "Source Sans 3" },
    "legend": { "labelFont": "Source Sans 3", "titleFont": "Source Sans 3" }
  },
  "params": [
    {
      "name": "species_filter",
      "value": null,
      "bind": {
        "input": "select",
        "options": [
          null,
          "White Shark",
          "Tiger Shark",
          "Bull Shark",
          "Wobbegong",
          "Whaler Shark",
          "Bronze Whaler",
          "Other"
        ],
        "labels": [
          "All species",
          "White Shark",
          "Tiger Shark",
          "Bull Shark",
          "Wobbegong",
          "Whaler Shark",
          "Bronze Whaler",
          "Other / unknown"
        ],
        "name": "Filter by species: "
      }
    }
  ],
  "transform": [
    { "calculate": "datum['Shark.length.m']", "as": "length_m" },
    { "calculate": "datum['Victim.injury']", "as": "outcome" },
    { "calculate": "datum['Species.clean']", "as": "species" },
    { "calculate": "datum['Incident.year']", "as": "year" },
    {
      "filter": "!species_filter || datum.species == species_filter"
    },
    {
      "calculate": "datum.outcome == 'fatal' ? 2 : datum.outcome == 'injured' ? 1 : 0",
      "as": "band"
    },
    {
      "calculate": "floor(datum.length_m * 4) / 4",
      "as": "length_bin"
    },
    {
      "window": [{ "op": "row_number", "as": "stack_idx" }],
      "groupby": ["band", "length_bin"],
      "sort": [{ "field": "length_m", "order": "ascending" }]
    },
    {
      "joinaggregate": [{ "op": "count", "as": "stack_n" }],
      "groupby": ["band", "length_bin"]
    },
    {
      "calculate": "datum.band + (datum.stack_idx - (datum.stack_n + 1) / 2) * (0.78 / datum.stack_n)",
      "as": "y_pos"
    }
  ],
  "layer": [
    {
      "description": "Background band for each outcome row",
      "data": {
        "values": [
          { "band": 0, "y0": -0.42, "y1": 0.42, "fill": "#f4f4f2" },
          { "band": 1, "y0": 0.58, "y1": 1.42, "fill": "#fff8f2" },
          { "band": 2, "y0": 1.58, "y1": 2.42, "fill": "#fdf3f3" }
        ]
      },
      "mark": { "type": "rect", "opacity": 0.85 },
      "encoding": {
        "x": { "value": 0, "scale": { "domain": [0, 7] } },
        "x2": { "value": 7 },
        "y": { "field": "y0", "type": "quantitative", "scale": { "domain": [-0.5, 2.5] } },
        "y2": { "field": "y1" },
        "color": { "field": "fill", "type": "nominal", "scale": null, "legend": null }
      }
    },
    {
      "description": "Horizontal separators between outcome rows",
      "data": {
        "values": [{ "y": 0.5 }, { "y": 1.5 }]
      },
      "mark": {
        "type": "rule",
        "stroke": "#dddddd",
        "strokeWidth": 1
      },
      "encoding": {
        "x": { "value": 0, "scale": { "domain": [0, 7] } },
        "x2": { "value": 7 },
        "y": { "field": "y", "type": "quantitative", "scale": { "domain": [-0.5, 2.5] } }
      }
    },
    {
      "description": "Average adult height reference at 1.7 m",
      "mark": {
        "type": "rule",
        "stroke": "#1a4a63",
        "strokeWidth": 1.2,
        "strokeDash": [5, 4],
        "opacity": 0.6
      },
      "encoding": {
        "x": { "datum": 1.7 },
        "y": { "datum": -0.5, "scale": { "domain": [-0.5, 2.5] } },
        "y2": { "datum": 2.5 }
      }
    },
    {
      "description": "Threshold where fatalities first appear",
      "mark": {
        "type": "rule",
        "stroke": "#c0392b",
        "strokeWidth": 1.4,
        "strokeDash": [3, 3],
        "opacity": 0.75
      },
      "encoding": {
        "x": { "datum": 2.0 },
        "y": { "datum": -0.5, "scale": { "domain": [-0.5, 2.5] } },
        "y2": { "datum": 2.5 }
      }
    },
    {
      "description": "Incident dots, stacked vertically when lengths overlap",
      "mark": {
        "type": "circle",
        "size": 36,
        "opacity": 0.88,
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      },
      "encoding": {
        "x": {
          "field": "length_m",
          "type": "quantitative",
          "scale": { "domain": [0, 7], "nice": false },
          "axis": {
            "title": "Shark length (m)",
            "grid": true,
            "gridColor": "#eeeeee",
            "values": [0, 1, 2, 3, 4, 5, 6, 7]
          }
        },
        "y": {
          "field": "y_pos",
          "type": "quantitative",
          "scale": { "domain": [-0.5, 2.5], "nice": false },
          "axis": {
            "title": null,
            "values": [0, 1, 2],
            "labelExpr": "datum.value == 2 ? 'Fatal' : datum.value == 1 ? 'Injured' : 'Uninjured'",
            "labelFontSize": 12,
            "labelFontWeight": "bold",
            "labelColor": "#1a2530",
            "ticks": false,
            "grid": false,
            "domain": false
          }
        },
        "color": {
          "field": "outcome",
          "type": "nominal",
          "scale": {
            "domain": ["fatal", "injured", "uninjured"],
            "range": ["#c0392b", "#e67e22", "#7f8c8d"]
          },
          "legend": {
            "title": "Outcome",
            "orient": "bottom",
            "direction": "horizontal",
            "offset": 4,
            "labelFontSize": 11
          }
        },
        "tooltip": [
          { "field": "length_m", "type": "quantitative", "title": "Length (m)", "format": ".1f" },
          { "field": "outcome", "title": "Outcome" },
          { "field": "species", "title": "Species" },
          { "field": "State", "title": "State" },
          { "field": "year", "title": "Year" }
        ]
      }
    },
    {
      "description": "Reference label left of 1.7 m line",
      "data": { "values": [{ "x": 1.7, "text": "Avg height 1.7 m" }] },
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -6,
        "baseline": "bottom",
        "dy": -4,
        "fontSize": 10,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "scale": { "domain": [0, 7] } },
        "y": { "datum": 2.5, "scale": { "domain": [-0.5, 2.5] } },
        "text": { "field": "text" },
        "color": { "value": "#1a4a63" }
      }
    },
    {
      "description": "Reference label right of 2 m line",
      "data": { "values": [{ "x": 2.0, "text": "Fatalities from 2 m" }] },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "baseline": "bottom",
        "dy": -4,
        "fontSize": 10,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "scale": { "domain": [0, 7] } },
        "y": { "datum": 2.5, "scale": { "domain": [-0.5, 2.5] } },
        "text": { "field": "text" },
        "color": { "value": "#c0392b" }
      }
    }
  ]
}
