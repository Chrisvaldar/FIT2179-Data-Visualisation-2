{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Incidents per million people by state",
    "anchor": "middle",
    "font": "Source Sans 3",
    "fontSize": 12,
    "fontWeight": "bold",
    "color": "#1a2530"
  },
  "width": 480,
  "height": 520,
  "autosize": {
    "type": "pad",
    "contains": "padding"
  },
  "padding": {
    "bottom": 4
  },
  "config": {
    "title": {
      "font": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": "transparent",
      "fill": "#eef4f7"
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "titleFontWeight": "bold",
      "orient": "bottom",
      "offset": 4,
      "direction": "horizontal",
      "titleOrient": "top",
      "titleAnchor": "start",
      "titleAlign": "left"
    }
  },
  "projection": {
    "type": "mercator",
    "center": [
      133,
      -27
    ],
    "scale": 540
  },
  "layer": [
    {
      "description": "States coloured by population-normalised incident rate",
      "data": {
        "url": "data/topojson/australia_states.json",
        "format": {
          "type": "topojson",
          "feature": "australia_states"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.name !== 'Lord Howe Island' && datum.properties.name !== 'Macquarie Island'"
        },
        {
          "calculate": "slice(datum.properties.iso_3166_2, 3)",
          "as": "state_abbrev"
        },
        {
          "lookup": "state_abbrev",
          "from": {
            "data": {
              "url": "data/wrangled_data/state_choropleth.csv"
            },
            "key": "State",
            "fields": [
              "total",
              "fatal",
              "fatal_rate",
              "population",
              "rate_per_million"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      },
      "encoding": {
        "color": {
          "field": "rate_per_million",
          "type": "quantitative",
          "scale": {
            "scheme": "blues",
            "domain": [
              0,
              80
            ]
          },
          "legend": {
            "title": "Incidents per million people",
            "orient": "bottom",
            "direction": "horizontal",
            "titleOrient": "top",
            "titleAnchor": "start",
            "titleAlign": "left",
            "gradientLength": 200,
            "labelFontSize": 10,
            "titleFontSize": 11,
            "titleFontWeight": "bold"
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "total",
            "type": "quantitative",
            "title": "Total incidents",
            "format": ","
          },
          {
            "field": "rate_per_million",
            "type": "quantitative",
            "title": "Incidents per million people",
            "format": ".1f"
          },
          {
            "field": "population",
            "type": "quantitative",
            "title": "Population (2021)",
            "format": ","
          },
          {
            "field": "fatal_rate",
            "type": "quantitative",
            "title": "Fatality rate (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "description": "State name labels (line above value)",
      "data": {
        "values": [
          {
            "state": "NSW",
            "lat": -32.0,
            "lon": 146.5,
            "name": "New South Wales",
            "value": "(53.6)"
          },
          {
            "state": "QLD",
            "lat": -22.5,
            "lon": 144.5,
            "name": "Queensland",
            "value": "(68.7)"
          },
          {
            "state": "WA",
            "lat": -25.0,
            "lon": 121.5,
            "name": "Western Australia",
            "value": "(70.6)"
          },
          {
            "state": "SA",
            "lat": -29.0,
            "lon": 135.5,
            "name": "South Australia",
            "value": "(40.5)"
          },
          {
            "state": "NT",
            "lat": -19.5,
            "lon": 133.5,
            "name": "Northern Territory",
            "value": "(75.9)"
          },
          {
            "state": "VIC",
            "lat": -37.0,
            "lon": 144.75,
            "name": "Victoria",
            "value": "(10.5)"
          },
          {
            "state": "TAS",
            "lat": -42.0,
            "lon": 146.6,
            "name": "Tasmania",
            "value": "(47.3)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 8,
        "fontWeight": "bold",
        "align": "center",
        "baseline": "middle",
        "dy": 3,
        "font": "Source Sans 3"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "name",
          "type": "nominal"
        },
        "color": {
          "condition": {
            "test": "datum.state === 'WA' || datum.state === 'NT' || datum.state === 'QLD'",
            "value": "#ffffff"
          },
          "value": "#1a2530"
        }
      }
    },
    {
      "description": "State value labels (line below name)",
      "data": {
        "values": [
          {
            "state": "NSW",
            "lat": -32.0,
            "lon": 146.5,
            "name": "New South Wales",
            "value": "(53.6)"
          },
          {
            "state": "QLD",
            "lat": -22.5,
            "lon": 144.5,
            "name": "Queensland",
            "value": "(68.7)"
          },
          {
            "state": "WA",
            "lat": -25.0,
            "lon": 121.5,
            "name": "Western Australia",
            "value": "(70.6)"
          },
          {
            "state": "SA",
            "lat": -29.0,
            "lon": 135.5,
            "name": "South Australia",
            "value": "(40.5)"
          },
          {
            "state": "NT",
            "lat": -19.5,
            "lon": 133.5,
            "name": "Northern Territory",
            "value": "(75.9)"
          },
          {
            "state": "VIC",
            "lat": -37.0,
            "lon": 144.75,
            "name": "Victoria",
            "value": "(10.5)"
          },
          {
            "state": "TAS",
            "lat": -42.0,
            "lon": 146.6,
            "name": "Tasmania",
            "value": "(47.3)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 8,
        "fontWeight": "bold",
        "align": "center",
        "baseline": "top",
        "dy": 11,
        "font": "Source Sans 3"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "value",
          "type": "nominal"
        },
        "color": {
          "condition": {
            "test": "datum.state === 'WA' || datum.state === 'NT' || datum.state === 'QLD'",
            "value": "#ffffff"
          },
          "value": "#1a2530"
        }
      }
    }
  ]
}
