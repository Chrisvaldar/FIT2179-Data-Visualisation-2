{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1000,
  "height": 380,
  "padding": {
    "top": 44,
    "right": 12,
    "bottom": 12
  },
  "config": {
    "title": {
      "font": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": "transparent",
      "clip": false
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "titleFontWeight": "bold",
      "orient": "bottom",
      "offset": 4,
      "direction": "horizontal",
      "titleOrient": "top",
      "titleAnchor": "start",
      "titleAlign": "left"
    }
  },
  "params": [
    {
      "name": "metric",
      "value": "count",
      "bind": {
        "input": "select",
        "options": [
          "count",
          "rate"
        ],
        "labels": [
          "Raw incident count",
          "Rate per million people"
        ],
        "name": "Show: "
      }
    }
  ],
  "data": {
    "url": "../../data/wrangled_data/decade_timeline.csv"
  },
  "layer": [
    {
      "description": "Stacked area for count mode, by outcome",
      "transform": [
        {
          "filter": "metric === 'count'"
        },
        {
          "fold": [
            "uninjured",
            "injured",
            "fatal"
          ],
          "as": [
            "outcome",
            "n"
          ]
        }
      ],
      "mark": {
        "type": "area",
        "opacity": 0.85,
        "line": false
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "quantitative",
          "scale": {
            "domain": [
              1790,
              2020
            ],
            "nice": false
          },
          "axis": {
            "title": "Decade",
            "values": [
              1800,
              1820,
              1840,
              1860,
              1880,
              1900,
              1920,
              1940,
              1960,
              1980,
              2000,
              2020
            ],
            "format": "d",
            "labelAngle": -45,
            "grid": false
          }
        },
        "y": {
          "field": "n",
          "type": "quantitative",
          "stack": "zero",
          "scale": {
            "domain": {
              "expr": "metric === 'count' ? [0, 280] : [0, 235]"
            },
            "nice": false
          },
          "axis": {
            "title": {
              "expr": "metric === 'count' ? 'Number of incidents' : 'Incidents per million people'"
            },
            "grid": true,
            "gridColor": "#eeeeee"
          }
        },
        "color": {
          "field": "outcome",
          "type": "nominal",
          "scale": {
            "domain": [
              "fatal",
              "injured",
              "uninjured"
            ],
            "range": [
              "#c0392b",
              "#e67e22",
              "#7f8c8d"
            ]
          },
          "legend": null
        },
        "order": {
          "field": "outcome",
          "sort": {
            "field": "outcome",
            "order": "descending"
          }
        },
        "tooltip": [
          {
            "field": "Decade",
            "type": "quantitative",
            "title": "Decade",
            "format": "d"
          },
          {
            "field": "total",
            "type": "quantitative",
            "title": "Total incidents"
          },
          {
            "field": "fatal",
            "type": "quantitative",
            "title": "Fatal"
          },
          {
            "field": "injured",
            "type": "quantitative",
            "title": "Injured"
          },
          {
            "field": "uninjured",
            "type": "quantitative",
            "title": "Uninjured"
          }
        ]
      }
    },
    {
      "description": "Rate per million area, single colour",
      "transform": [
        {
          "filter": "metric === 'rate'"
        }
      ],
      "mark": {
        "type": "area",
        "color": "#1a4a63",
        "opacity": 0.85,
        "line": false
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "quantitative"
        },
        "y": {
          "field": "rate_per_million",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "Decade",
            "type": "quantitative",
            "title": "Decade",
            "format": "d"
          },
          {
            "field": "rate_per_million",
            "type": "quantitative",
            "title": "Rate per million",
            "format": ".2f"
          },
          {
            "field": "total",
            "type": "quantitative",
            "title": "Raw count"
          },
          {
            "field": "population_m",
            "type": "quantitative",
            "title": "Population (millions)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "description": "Raw count peak annotation",
      "transform": [
        {
          "filter": "metric === 'count'"
        }
      ],
      "data": {
        "values": [
          {
            "Decade": 2010,
            "y": 231,
            "label": "231 incidents\nin the 2010s"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "dx": -6,
        "dy": -6,
        "lineBreak": "\n",
        "fontSize": 11,
        "fontStyle": "italic",
        "fill": "#2c3e50",
        "clip": false,
        "font": "Source Sans 3"
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Raw count WW2 annotation",
      "transform": [
        {
          "filter": "metric === 'count'"
        }
      ],
      "data": {
        "values": [
          {
            "Decade": 1940,
            "y": 51,
            "label": "WW2 kept people\noff the beaches"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dy": 8,
        "lineBreak": "\n",
        "fontSize": 11,
        "fontStyle": "italic",
        "fill": "#2c3e50",
        "clip": false,
        "font": "Source Sans 3"
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Rate early population annotation",
      "transform": [
        {
          "filter": "metric === 'rate'"
        }
      ],
      "data": {
        "values": [
          {
            "Decade": 1800,
            "y": 200,
            "label": "Very few people\nback then"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 8,
        "dy": -6,
        "lineBreak": "\n",
        "fontSize": 11,
        "fontStyle": "italic",
        "fill": "#2c3e50",
        "clip": false,
        "font": "Source Sans 3"
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Rate federation annotation",
      "transform": [
        {
          "filter": "metric === 'rate'"
        }
      ],
      "data": {
        "values": [
          {
            "Decade": 2000,
            "y": 45,
            "label": "Fairly steady\nsince federation"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "lineBreak": "\n",
        "fontSize": 11,
        "fontStyle": "italic",
        "fill": "#2c3e50",
        "clip": false,
        "font": "Source Sans 3"
      },
      "encoding": {
        "x": {
          "field": "Decade",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}
