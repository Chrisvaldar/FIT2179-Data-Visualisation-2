{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 640,
  "autosize": {
    "type": "fit-x",
    "contains": "padding",
    "resize": true
  },
  "padding": {
    "bottom": 28
  },
  "config": {
    "title": {
      "font": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": "transparent",
      "clip": true
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "titleFontWeight": "bold",
      "orient": "bottom",
      "direction": "horizontal",
      "titleOrient": "top",
      "titleAnchor": "start",
      "titleAlign": "left"
    }
  },
  "params": [
    {
      "name": "state_select",
      "value": null,
      "bind": {
        "input": "select",
        "options": [
          null,
          "NSW",
          "QLD",
          "VIC",
          "WA",
          "SA",
          "TAS",
          "NT"
        ],
        "labels": [
          "All Australia",
          "New South Wales",
          "Queensland",
          "Victoria",
          "Western Australia",
          "South Australia",
          "Tasmania",
          "Northern Territory"
        ],
        "name": "Zoom to state: "
      }
    },
    {
      "name": "decade_select",
      "value": null,
      "bind": {
        "input": "select",
        "options": [
          null,
          1790,
          1800,
          1810,
          1820,
          1830,
          1840,
          1850,
          1860,
          1870,
          1880,
          1890,
          1900,
          1910,
          1920,
          1930,
          1940,
          1950,
          1960,
          1970,
          1980,
          1990,
          2000,
          2010,
          2020
        ],
        "labels": [
          "All decades",
          "1790s",
          "1800s",
          "1810s",
          "1820s",
          "1830s",
          "1840s",
          "1850s",
          "1860s",
          "1870s",
          "1880s",
          "1890s",
          "1900s",
          "1910s",
          "1920s",
          "1930s",
          "1940s",
          "1950s",
          "1960s",
          "1970s",
          "1980s",
          "1990s",
          "2000s",
          "2010s",
          "2020s"
        ],
        "name": "Filter by decade: "
      }
    },
    {
      "name": "outcome_select",
      "value": "all",
      "bind": {
        "input": "select",
        "options": [
          "all",
          "fatal",
          "injured",
          "uninjured"
        ],
        "labels": [
          "All outcomes",
          "Fatal only",
          "Injured only",
          "Uninjured only"
        ],
        "name": "Filter by outcome: "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": {
      "expr": "state_select == null ? [133, -27] : state_select == 'NSW' ? [146.0, -32.0] : state_select == 'QLD' ? [145.0, -18.8] : state_select == 'VIC' ? [144.8, -38.4] : state_select == 'WA' ? [114.0, -25.0] : state_select == 'SA' ? [136.8, -35.1] : state_select == 'TAS' ? [146.4, -41.8] : state_select == 'NT' ? [133.2, -12.8] : [133, -27]"
    },
    "scale": {
      "expr": "state_select == null ? 850 : state_select == 'NSW' ? 2100 : state_select == 'QLD' ? 1600 : state_select == 'VIC' ? 4000 : state_select == 'WA' ? 1400 : state_select == 'SA' ? 1800 : state_select == 'TAS' ? 2450 : state_select == 'NT' ? 3600 : 850"
    }
  },
  "layer": [
    {
      "description": "Ocean background",
      "data": {
        "values": [
          {}
        ]
      },
      "mark": {
        "type": "rect",
        "fill": "#dbe7ee",
        "x": 0,
        "y": 0,
        "x2": {
          "expr": "width"
        },
        "y2": {
          "expr": "height"
        }
      }
    },
    {
      "description": "Australia land mass, soft sand fill",
      "data": {
        "url": "data/topojson/australia.json",
        "format": {
          "type": "topojson",
          "feature": "australia"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f4e9d3",
        "stroke": "#b89968",
        "strokeWidth": 0.7
      }
    },
    {
      "description": "State boundaries layered on top of the country mass",
      "data": {
        "url": "data/topojson/australia_states.json",
        "format": {
          "type": "topojson",
          "feature": "australia_states"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "#ffffff",
        "strokeWidth": 1.1,
        "strokeOpacity": 0.9
      }
    },
    {
      "description": "State labels positioned at state centroids, ghosted into the land",
      "data": {
        "values": [
          {
            "state": "NSW",
            "label": "New South Wales",
            "lat": -32.4751,
            "lon": 146.781
          },
          {
            "state": "QLD",
            "label": "Queensland",
            "lat": -23.1364,
            "lon": 144.778
          },
          {
            "state": "WA",
            "label": "Western Australia",
            "lat": -25.8483,
            "lon": 121.646
          },
          {
            "state": "SA",
            "label": "South Australia",
            "lat": -29.6504,
            "lon": 135.783
          },
          {
            "state": "VIC",
            "label": "Victoria",
            "lat": -37.0082,
            "lon": 144.75
          },
          {
            "state": "TAS",
            "label": "Tasmania",
            "lat": -42.1383,
            "lon": 146.603
          },
          {
            "state": "NT",
            "label": "Northern Territory",
            "lat": -20.1026,
            "lon": 133.78
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "fill": "#8a6e3a",
        "fillOpacity": 0.7,
        "font": "Source Sans 3"
      },
      "transform": [
        {
          "filter": "state_select === null || datum.state == state_select"
        }
      ],
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Incident dots, filtered by state zoom, decade, and outcome selectors",
      "data": {
        "url": "data/wrangled_data/dot_map.csv"
      },
      "transform": [
        {
          "filter": "state_select === null || datum.State == state_select"
        },
        {
          "filter": "decade_select === null || datum.Decade == decade_select"
        },
        {
          "filter": "outcome_select === 'all' || datum['Victim.injury'] === outcome_select"
        },
        {
          "calculate": "datum.State == 'NSW' ? 'New South Wales' : datum.State == 'QLD' ? 'Queensland' : datum.State == 'VIC' ? 'Victoria' : datum.State == 'TAS' ? 'Tasmania' : datum.State == 'WA' ? 'Western Australia' : datum.State == 'SA' ? 'South Australia' : datum.State == 'NT' ? 'Northern Territory' : datum.State",
          "as": "State_full"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.78,
        "filled": true,
        "stroke": "white",
        "strokeWidth": 0.4
      },
      "encoding": {
        "longitude": {
          "field": "Longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "Latitude",
          "type": "quantitative"
        },
        "color": {
          "field": "Victim\\.injury",
          "type": "nominal",
          "scale": {
            "domain": [
              "fatal",
              "injured",
              "uninjured"
            ],
            "range": [
              "#c0392b",
              "#e67e22",
              "#7f8c8d"
            ]
          },
          "legend": {
            "title": "Outcome",
            "orient": "bottom",
            "direction": "horizontal",
            "titleOrient": "top",
            "titleAnchor": "start",
            "titleAlign": "left",
            "offset": 8,
            "labelExpr": "datum.label === 'fatal' ? 'Fatal' : datum.label === 'injured' ? 'Injured' : 'Uninjured'",
            "labelFontSize": 12,
            "labelFontStyle": "normal",
            "titleFontSize": 12,
            "titleFontStyle": "normal",
            "titleFontWeight": "bold"
          }
        },
        "size": {
          "condition": {
            "test": "datum['Victim.injury'] === 'fatal'",
            "value": 55
          },
          "value": 38
        },
        "tooltip": [
          {
            "field": "Incident\\.year",
            "title": "Year"
          },
          {
            "field": "Location",
            "title": "Location"
          },
          {
            "field": "State_full",
            "title": "State"
          },
          {
            "field": "Species\\.clean",
            "title": "Shark"
          },
          {
            "field": "Activity\\.clean",
            "title": "Activity"
          },
          {
            "field": "Victim\\.injury",
            "title": "Outcome"
          },
          {
            "field": "Provoked\\.unprovoked",
            "title": "Provoked or unprovoked"
          }
        ]
      }
    },
    {
      "description": "NSW coast annotation, text sits east in the Tasman Sea",
      "data": {
        "values": [
          {
            "lon": 151.18,
            "lat": -33.54,
            "label": "Densest stretch of coast"
          }
        ]
      },
      "transform": [
        {
          "filter": "state_select === null || state_select == 'NSW'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 14,
        "fontSize": 12,
        "fontStyle": "italic",
        "fill": "#000000",
        "font": "Source Sans 3"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "WA coast annotation, text sits west in the Indian Ocean",
      "data": {
        "values": [
          {
            "lon": 115.72,
            "lat": -31.95,
            "label": "Sparse, spread across a vast coast"
          }
        ]
      },
      "transform": [
        {
          "filter": "state_select === null || state_select == 'WA'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "dx": -14,
        "fontSize": 12,
        "fontStyle": "italic",
        "fill": "#000000",
        "font": "Source Sans 3"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}
