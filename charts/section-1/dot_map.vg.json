{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1000,
  "spacing": 0,
  "autosize": {
    "type": "pad"
  },
  "config": {
    "title": {
      "font": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": "transparent",
      "clip": false
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "titleFontWeight": "bold",
      "orient": "bottom",
      "direction": "horizontal",
      "titleOrient": "top",
      "titleAnchor": "start",
      "titleAlign": "left"
    },
    "concat": {
      "spacing": 0
    }
  },
  "params": [
    {
      "name": "state_select",
      "value": null,
      "bind": {
        "input": "select",
        "options": [
          null,
          "NSW",
          "QLD",
          "VIC",
          "WA",
          "SA",
          "TAS",
          "NT"
        ],
        "labels": [
          "All Australia",
          "New South Wales",
          "Queensland",
          "Victoria",
          "Western Australia",
          "South Australia",
          "Tasmania",
          "Northern Territory"
        ],
        "name": "Zoom to state: "
      }
    },
    {
      "name": "outcome_select",
      "value": "all",
      "bind": {
        "input": "select",
        "options": [
          "all",
          "fatal",
          "injured",
          "uninjured"
        ],
        "labels": [
          "All outcomes",
          "Fatal only",
          "Injured only",
          "Uninjured only"
        ],
        "name": "Filter by outcome: "
      }
    },
    {
      "name": "metric",
      "value": "count",
      "bind": {
        "input": "select",
        "options": [
          "count",
          "rate"
        ],
        "labels": [
          "Raw incident count",
          "Rate per million people"
        ],
        "name": "Show: "
      }
    }
  ],
  "vconcat": [
    {
      "width": 1000,
      "height": 700,
      "padding": {
        "bottom": 0
      },
      "projection": {
        "type": "mercator",
        "center": {
          "expr": "state_select == null ? [133, -5] : state_select == 'NSW' ? [146.0, -32.0] : state_select == 'QLD' ? [145.0, -18.8] : state_select == 'VIC' ? [144.8, -38.4] : state_select == 'WA' ? [114.0, -25.0] : state_select == 'SA' ? [136.8, -35.1] : state_select == 'TAS' ? [146.4, -41.8] : state_select == 'NT' ? [133.2, -12.8] : [133, -27]"
        },
        "scale": {
          "expr": "state_select == null ? 850 : state_select == 'NSW' ? 2100 : state_select == 'QLD' ? 1600 : state_select == 'VIC' ? 4000 : state_select == 'WA' ? 1400 : state_select == 'SA' ? 1800 : state_select == 'TAS' ? 2450 : state_select == 'NT' ? 3600 : 850"
        }
      },
      "layer": [
        {
          "description": "Ocean background",
          "data": {
            "values": [
              {}
            ]
          },
          "mark": {
            "type": "rect",
            "fill": "#dbe7ee",
            "x": 0,
            "y": 0,
            "x2": {
              "expr": "width"
            },
            "y2": {
              "expr": "height"
            }
          }
        },
        {
          "description": "Australia land mass, soft sand fill",
          "data": {
            "url": "data/topojson/australia.json",
            "format": {
              "type": "topojson",
              "feature": "australia"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#f4e9d3",
            "stroke": "#b89968",
            "strokeWidth": 0.7
          }
        },
        {
          "description": "State boundaries layered on top of the country mass",
          "data": {
            "url": "data/topojson/australia_states.json",
            "format": {
              "type": "topojson",
              "feature": "australia_states"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": null,
            "stroke": "#ffffff",
            "strokeWidth": 1.1,
            "strokeOpacity": 0.9
          }
        },
        {
          "description": "State labels positioned at state centroids, ghosted into the land",
          "data": {
            "values": [
              {
                "state": "NSW",
                "label": "New South Wales",
                "lat": -32.4751,
                "lon": 146.781
              },
              {
                "state": "QLD",
                "label": "Queensland",
                "lat": -23.1364,
                "lon": 144.778
              },
              {
                "state": "WA",
                "label": "Western Australia",
                "lat": -25.8483,
                "lon": 121.646
              },
              {
                "state": "SA",
                "label": "South Australia",
                "lat": -29.6504,
                "lon": 135.783
              },
              {
                "state": "VIC",
                "label": "Victoria",
                "lat": -37.0082,
                "lon": 144.75
              },
              {
                "state": "TAS",
                "label": "Tasmania",
                "lat": -42.1383,
                "lon": 146.603
              },
              {
                "state": "NT",
                "label": "Northern Territory",
                "lat": -20.1026,
                "lon": 133.78
              }
            ]
          },
          "transform": [
            {
              "filter": "state_select === null || datum.state == state_select"
            }
          ],
          "mark": {
            "type": "text",
            "fontSize": 12,
            "fontWeight": "bold",
            "fill": "#8a6e3a",
            "fillOpacity": 0.7,
            "font": "Source Sans 3"
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "description": "Incident dots, filtered by state zoom, decade brush, and outcome selector",
          "data": {
            "url": "data/wrangled_data/dot_map.csv"
          },
          "transform": [
            {
              "filter": "state_select === null || datum.State == state_select"
            },
            {
              "filter": {
                "param": "decade_brush"
              }
            },
            {
              "filter": "outcome_select === 'all' || datum['Victim.injury'] === outcome_select"
            },
            {
              "calculate": "datum.State == 'NSW' ? 'New South Wales' : datum.State == 'QLD' ? 'Queensland' : datum.State == 'VIC' ? 'Victoria' : datum.State == 'TAS' ? 'Tasmania' : datum.State == 'WA' ? 'Western Australia' : datum.State == 'SA' ? 'South Australia' : datum.State == 'NT' ? 'Northern Territory' : datum.State",
              "as": "State_full"
            }
          ],
          "mark": {
            "type": "circle",
            "opacity": 0.78,
            "filled": true,
            "stroke": "white",
            "strokeWidth": 0.4
          },
          "encoding": {
            "longitude": {
              "field": "Longitude",
              "type": "quantitative"
            },
            "latitude": {
              "field": "Latitude",
              "type": "quantitative"
            },
            "color": {
              "field": "Victim\\.injury",
              "type": "nominal",
              "scale": {
                "domain": [
                  "fatal",
                  "injured",
                  "uninjured"
                ],
                "range": [
                  "#c0392b",
                  "#e67e22",
                  "#7f8c8d"
                ]
              },
              "legend": null
            },
            "size": {
              "condition": {
                "test": "datum['Victim.injury'] === 'fatal'",
                "value": 55
              },
              "value": 38
            },
            "tooltip": [
              {
                "field": "Incident\\.year",
                "title": "Year"
              },
              {
                "field": "Location",
                "title": "Location"
              },
              {
                "field": "State_full",
                "title": "State"
              },
              {
                "field": "Species\\.clean",
                "title": "Shark"
              },
              {
                "field": "Activity\\.clean",
                "title": "Activity"
              },
              {
                "field": "Victim\\.injury",
                "title": "Outcome"
              },
              {
                "field": "Provoked\\.unprovoked",
                "title": "Provoked or unprovoked"
              }
            ]
          }
        },
        {
          "description": "NSW coast annotation, text sits east in the Tasman Sea",
          "data": {
            "values": [
              {
                "lon": 151.18,
                "lat": -33.54,
                "label": "Densest stretch of coast"
              }
            ]
          },
          "transform": [
            {
              "filter": "state_select === null || state_select == 'NSW'"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "middle",
            "dx": 14,
            "fontSize": 12,
            "fontStyle": "italic",
            "fill": "#000000",
            "font": "Source Sans 3"
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "description": "WA coast annotation, text sits west in the Indian Ocean",
          "data": {
            "values": [
              {
                "lon": 115.72,
                "lat": -31.95,
                "label": "Sparse, spread across a vast coast"
              }
            ]
          },
          "transform": [
            {
              "filter": "state_select === null || state_select == 'WA'"
            }
          ],
          "mark": {
            "type": "text",
            "align": "right",
            "baseline": "middle",
            "dx": -14,
            "fontSize": 12,
            "fontStyle": "italic",
            "fill": "#000000",
            "font": "Source Sans 3"
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        }
      ]
    },
    {
      "width": 1000,
      "height": 240,
      "padding": {
        "top": 6,
        "right": 12,
        "bottom": 64,
        "left": 56
      },
      "autosize": {
        "type": "pad"
      },
      "config": {
        "view": {
          "stroke": "transparent",
          "clip": false
        },
        "axisX": {
          "labelFont": "Source Sans 3",
          "titleFont": "Source Sans 3",
          "titlePadding": 12,
          "labelPadding": 6
        },
        "axisY": {
          "labelFont": "Source Sans 3",
          "titleFont": "Source Sans 3",
          "titlePadding": 8
        }
      },
      "data": {
        "url": "data/wrangled_data/decade_timeline.csv"
      },
      "layer": [
        {
          "description": "Stacked area for count mode, by outcome",
          "transform": [
            {
              "filter": "metric === 'count'"
            },
            {
              "fold": [
                "uninjured",
                "injured",
                "fatal"
              ],
              "as": [
                "outcome",
                "n"
              ]
            }
          ],
          "mark": {
            "type": "area",
            "opacity": 0.85,
            "line": false
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative",
              "scale": {
                "domain": [
                  1790,
                  2020
                ],
                "nice": false
              }
            },
            "y": {
              "field": "n",
              "type": "quantitative",
              "stack": "zero",
              "scale": {
                "domain": {
                  "expr": "metric === 'count' ? [0, 280] : [0, 235]"
                },
                "nice": false
              }
            },
            "color": {
              "field": "outcome",
              "type": "nominal",
              "scale": {
                "domain": [
                  "fatal",
                  "injured",
                  "uninjured"
                ],
                "range": [
                  "#c0392b",
                  "#e67e22",
                  "#7f8c8d"
                ]
              },
              "legend": null
            },
            "order": {
              "field": "outcome",
              "sort": {
                "field": "outcome",
                "order": "descending"
              }
            },
            "tooltip": [
              {
                "field": "Decade",
                "type": "quantitative",
                "title": "Decade",
                "format": "d"
              },
              {
                "field": "total",
                "type": "quantitative",
                "title": "Total incidents"
              },
              {
                "field": "fatal",
                "type": "quantitative",
                "title": "Fatal"
              },
              {
                "field": "injured",
                "type": "quantitative",
                "title": "Injured"
              },
              {
                "field": "uninjured",
                "type": "quantitative",
                "title": "Uninjured"
              }
            ]
          }
        },
        {
          "description": "Rate per million area, single colour",
          "transform": [
            {
              "filter": "metric === 'rate'"
            }
          ],
          "mark": {
            "type": "area",
            "color": "#1a4a63",
            "opacity": 0.85,
            "line": false
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative",
              "scale": {
                "domain": [1790, 2020],
                "nice": false
              }
            },
            "y": {
              "field": "rate_per_million",
              "type": "quantitative",
              "scale": {
                "domain": [0, 235],
                "nice": false
              }
            },
            "tooltip": [
              {
                "field": "Decade",
                "type": "quantitative",
                "title": "Decade",
                "format": "d"
              },
              {
                "field": "rate_per_million",
                "type": "quantitative",
                "title": "Rate per million",
                "format": ".2f"
              },
              {
                "field": "total",
                "type": "quantitative",
                "title": "Raw count"
              },
              {
                "field": "population_m",
                "type": "quantitative",
                "title": "Population (millions)",
                "format": ".2f"
              }
            ]
          }
        },
        {
          "description": "Raw count peak annotation",
          "transform": [
            {
              "filter": "metric === 'count'"
            }
          ],
          "data": {
            "values": [
              {
                "Decade": 2010,
                "y": 231,
                "label": "231 incidents\nin the 2010s"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "right",
            "baseline": "bottom",
            "dx": -6,
            "dy": -6,
            "lineBreak": "\n",
            "fontSize": 12,
            "fontStyle": "italic",
            "fill": "#2c3e50",
            "clip": false,
            "font": "Source Sans 3"
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative"
            },
            "y": {
              "field": "y",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "description": "Raw count WW2 annotation",
          "transform": [
            {
              "filter": "metric === 'count'"
            }
          ],
          "data": {
            "values": [
              {
                "Decade": 1940,
                "y": 51,
                "label": "WW2 kept people\noff the beaches"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "center",
            "baseline": "top",
            "dy": 8,
            "lineBreak": "\n",
            "fontSize": 12,
            "fontStyle": "italic",
            "fill": "#2c3e50",
            "clip": false,
            "font": "Source Sans 3"
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative"
            },
            "y": {
              "field": "y",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "description": "Rate early population annotation",
          "transform": [
            {
              "filter": "metric === 'rate'"
            }
          ],
          "data": {
            "values": [
              {
                "Decade": 1800,
                "y": 200,
                "label": "Very few people\nback then"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "bottom",
            "dx": 8,
            "dy": -6,
            "lineBreak": "\n",
            "fontSize": 12,
            "fontStyle": "italic",
            "fill": "#2c3e50",
            "clip": false,
            "font": "Source Sans 3"
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative"
            },
            "y": {
              "field": "y",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "description": "Rate federation annotation",
          "transform": [
            {
              "filter": "metric === 'rate'"
            }
          ],
          "data": {
            "values": [
              {
                "Decade": 2000,
                "y": 45,
                "label": "Fairly steady\nsince federation"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "middle",
            "dx": 8,
            "lineBreak": "\n",
            "fontSize": 12,
            "fontStyle": "italic",
            "fill": "#2c3e50",
            "clip": false,
            "font": "Source Sans 3"
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative"
            },
            "y": {
              "field": "y",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "description": "Decade brush: drag on timeline to filter map",
          "mark": {
            "type": "bar",
            "opacity": 0,
            "tooltip": null
          },
          "encoding": {
            "x": {
              "field": "Decade",
              "type": "quantitative",
              "scale": {
                "domain": [1790, 2020],
                "nice": false
              },
              "axis": {
                "title": "Decade (drag to filter map, double-click to reset)",
                "titlePadding": 12,
                "labelPadding": 6,
                "values": [
                  1800,
                  1820,
                  1840,
                  1860,
                  1880,
                  1900,
                  1920,
                  1940,
                  1960,
                  1980,
                  2000,
                  2020
                ],
                "format": "d",
                "labelAngle": -45,
                "grid": false
              }
            },
            "y": {
              "field": "total",
              "type": "quantitative",
              "aggregate": "max",
              "scale": {
                "domain": {
                  "expr": "metric === 'count' ? [0, 280] : [0, 235]"
                },
                "nice": false
              },
              "axis": {
                "title": {
                  "expr": "metric === 'count' ? 'Number of incidents' : 'Incidents per million people'"
                },
                "titlePadding": 8,
                "grid": true,
                "gridColor": "#eeeeee"
              }
            }
          },
          "params": [
            {
              "name": "decade_brush",
              "select": {
                "type": "interval",
                "encodings": ["x"]
              }
            }
          ]
        }
      ]
    }
  ]
}