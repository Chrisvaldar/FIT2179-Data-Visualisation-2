{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1000,
  "height": 380,
  "padding": {
    "bottom": 4
  },
  "autosize": {
    "type": "pad",
    "contains": "padding",
    "resize": true
  },
  "data": {
    "url": "../../data/wrangled_data/activity_risk.csv"
  },
  "transform": [
    {
      "calculate": "-datum.count",
      "as": "count_neg"
    },
    {
      "calculate": "datum['Activity.clean']",
      "as": "activity"
    }
  ],
  "config": {
    "title": {
      "font": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    }
  },
  "hconcat": [
    {
      "title": {
        "text": "Number of incidents",
        "font": "Source Sans 3",
        "fontSize": 12,
        "fontWeight": "bold",
        "anchor": "middle",
        "color": "#1a2530"
      },
      "width": 410,
      "height": 380,
      "layer": [
        {
          "description": "Lollipop stem from 0 to count_neg",
          "mark": {
            "type": "rule",
            "strokeWidth": 2.4,
            "color": "#3d5263"
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "x": {
              "field": "count_neg",
              "type": "quantitative",
              "scale": {
                "domain": [
                  -500,
                  0
                ],
                "nice": false
              },
              "axis": {
                "title": null,
                "labelExpr": "abs(datum.value)",
                "values": [
                  -500,
                  -450,
                  -400,
                  -350,
                  -300,
                  -250,
                  -200,
                  -150,
                  -100,
                  -50,
                  0
                ],
                "grid": true,
                "gridColor": "#eeeeee"
              }
            },
            "x2": {
              "datum": 0
            },
            "tooltip": [
              {
                "field": "activity",
                "title": "Activity"
              },
              {
                "field": "count",
                "title": "Total incidents"
              },
              {
                "field": "fatal",
                "title": "Fatal"
              },
              {
                "field": "fatal_rate",
                "title": "Incident fatality (%)",
                "format": ".1f"
              }
            ]
          }
        },
        {
          "description": "Lollipop head circle",
          "mark": {
            "type": "circle",
            "size": 110,
            "color": "#3d5263",
            "stroke": "#ffffff",
            "strokeWidth": 1.2
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "x": {
              "field": "count_neg",
              "type": "quantitative",
              "scale": {
                "domain": [
                  -500,
                  0
                ],
                "nice": false
              }
            }
          }
        },
        {
          "description": "Count label sitting next to each circle",
          "mark": {
            "type": "text",
            "fontSize": 11,
            "fontWeight": "bold",
            "color": "#1a2530",
            "align": "right",
            "dx": -10,
            "font": "Source Sans 3"
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "x": {
              "field": "count_neg",
              "type": "quantitative"
            },
            "text": {
              "field": "count",
              "type": "quantitative"
            }
          }
        }
      ]
    },
    {
      "title": {
        "text": "Activity",
        "font": "Source Sans 3",
        "fontSize": 12,
        "fontWeight": "bold",
        "anchor": "middle",
        "color": "#1a2530"
      },
      "width": 180,
      "height": 380,
      "layer": [
        {
          "description": "Activity name in the central column",
          "mark": {
            "type": "text",
            "fontSize": 12,
            "fontWeight": "bold",
            "color": "#1a2530",
            "align": "center",
            "font": "Source Sans 3"
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "text": {
              "field": "activity",
              "type": "nominal"
            }
          }
        }
      ],
      "view": {
        "stroke": "transparent"
      }
    },
    {
      "title": {
        "text": "Incident fatality (%)",
        "font": "Source Sans 3",
        "fontSize": 12,
        "fontWeight": "bold",
        "anchor": "middle",
        "color": "#1a2530"
      },
      "width": 410,
      "height": 380,
      "layer": [
        {
          "description": "Lollipop stem in red",
          "mark": {
            "type": "rule",
            "strokeWidth": 2.4,
            "color": "#c0392b"
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "x": {
              "field": "fatal_rate",
              "type": "quantitative",
              "scale": {
                "domain": [
                  0,
                  50
                ],
                "nice": false
              },
              "axis": {
                "title": null,
                "grid": true,
                "gridColor": "#eeeeee",
                "values": [
                  0,
                  5,
                  10,
                  15,
                  20,
                  25,
                  30,
                  35,
                  40,
                  45,
                  50
                ]
              }
            },
            "x2": {
              "datum": 0
            },
            "tooltip": [
              {
                "field": "activity",
                "title": "Activity"
              },
              {
                "field": "count",
                "title": "Total incidents"
              },
              {
                "field": "fatal",
                "title": "Fatal"
              },
              {
                "field": "fatal_rate",
                "title": "Incident fatality (%)",
                "format": ".1f"
              }
            ]
          }
        },
        {
          "description": "Lollipop head circle",
          "mark": {
            "type": "circle",
            "size": 110,
            "color": "#c0392b",
            "stroke": "#ffffff",
            "strokeWidth": 1.2
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "x": {
              "field": "fatal_rate",
              "type": "quantitative",
              "scale": {
                "domain": [
                  0,
                  50
                ],
                "nice": false
              }
            }
          }
        },
        {
          "description": "Fatality rate label next to each red circle",
          "mark": {
            "type": "text",
            "fontSize": 11,
            "fontWeight": "bold",
            "color": "#1a2530",
            "align": "left",
            "dx": 10,
            "font": "Source Sans 3"
          },
          "encoding": {
            "y": {
              "field": "activity",
              "type": "nominal",
              "sort": [
                "Swimming",
                "Surfing/Boarding",
                "Snorkelling",
                "Spearfishing",
                "Diving",
                "Fishing",
                "Boating",
                "Standing in Water"
              ],
              "axis": null
            },
            "x": {
              "field": "fatal_rate",
              "type": "quantitative"
            },
            "text": {
              "field": "fatal_rate",
              "type": "quantitative",
              "format": ".1f"
            }
          }
        }
      ]
    }
  ],
  "spacing": 0
}
