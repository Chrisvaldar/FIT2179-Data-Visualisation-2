{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1000,
  "height": 360,
  "padding": {
    "top": 36,
    "left": 8,
    "right": 12,
    "bottom": 28
  },
  "data": {
    "url": "data/wrangled_data/age_records.csv"
  },
  "config": {
    "title": {
      "font": "Source Sans 3"
    },
    "text": {
      "font": "Source Sans 3"
    },
    "view": {
      "stroke": "transparent",
      "clip": false
    },
    "axis": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3"
    },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "titleFontWeight": "bold"
    }
  },
  "layer": [
    {
      "description": "Mirrored kernel density: fatal above centre, survived below",
      "transform": [
        {
          "calculate": "toNumber(datum['Victim.age'])",
          "as": "age"
        },
        {
          "calculate": "datum.outcome_group",
          "as": "side"
        },
        {
          "density": "age",
          "groupby": [
            "side"
          ],
          "extent": [
            0,
            80
          ],
          "steps": 160,
          "bandwidth": 3.5,
          "counts": true,
          "as": [
            "age_value",
            "density"
          ]
        },
        {
          "calculate": "datum.side == 'fatal' ? datum.density : -datum.density",
          "as": "signed_density"
        }
      ],
      "mark": {
        "type": "area",
        "opacity": 0.78,
        "line": {
          "strokeWidth": 1.5,
          "color": "#ffffff"
        },
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "age_value",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              80
            ],
            "nice": false
          },
          "axis": {
            "title": "Victim age (years)",
            "grid": true,
            "gridColor": "#eeeeee",
            "values": [
              0,
              10,
              20,
              30,
              40,
              50,
              60,
              70,
              80
            ]
          }
        },
        "y": {
          "field": "signed_density",
          "type": "quantitative",
          "scale": {
            "domain": [
              -45,
              45
            ],
            "nice": false
          },
          "axis": null
        },
        "y2": {
          "datum": 0
        },
        "color": {
          "field": "side",
          "type": "nominal",
          "scale": {
            "domain": [
              "fatal",
              "survived"
            ],
            "range": [
              "#c0392b",
              "#1a6b8a"
            ]
          },
          "legend": {
            "title": "Outcome",
            "orient": "bottom",
            "direction": "horizontal",
            "titleOrient": "top",
            "titleAnchor": "start",
            "titleAlign": "left",
            "offset": 4,
            "labelFontSize": 11,
            "titleFontSize": 11,
            "titleFontWeight": "bold",
            "labelExpr": "datum.label == 'fatal' ? 'Fatal' : 'Survived (injured or uninjured)'"
          }
        },
        "tooltip": [
          {
            "field": "age_value",
            "type": "quantitative",
            "title": "Age (years)",
            "format": ".0f"
          },
          {
            "field": "density",
            "type": "quantitative",
            "title": "Estimated count",
            "format": ".1f"
          },
          {
            "field": "side",
            "title": "Group"
          }
        ]
      }
    },
    {
      "description": "Centre baseline between fatal and survived halves",
      "data": {
        "values": [
          {
            "age_value": 0,
            "signed_density": 0
          },
          {
            "age_value": 80,
            "signed_density": 0
          }
        ]
      },
      "mark": {
        "type": "rule",
        "stroke": "#1a2530",
        "strokeWidth": 1.2,
        "opacity": 0.35
      },
      "encoding": {
        "x": {
          "field": "age_value",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              80
            ],
            "nice": false
          }
        },
        "y": {
          "field": "signed_density",
          "type": "quantitative",
          "scale": {
            "domain": [
              -45,
              45
            ],
            "nice": false
          }
        }
      }
    },
    {
      "description": "Fatal peak annotation anchored to age 16 on the ridge",
      "data": {
        "values": [
          {
            "age_value": 16,
            "signed_density": 6.8,
            "label": "Fatal peak\n16 years"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -18,
        "lineBreak": "\n",
        "fontSize": 11,
        "fontStyle": "italic",
        "fill": "#2c3e50",
        "clip": false,
        "font": "Source Sans 3"
      },
      "encoding": {
        "x": {
          "field": "age_value",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              80
            ],
            "nice": false
          }
        },
        "y": {
          "field": "signed_density",
          "type": "quantitative",
          "scale": {
            "domain": [
              -45,
              45
            ],
            "nice": false
          }
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Survived peak annotation anchored to age 17 on the ridge",
      "data": {
        "values": [
          {
            "age_value": 17,
            "signed_density": -17.9,
            "label": "Survived peak\n17 years"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dy": 8,
        "lineBreak": "\n",
        "fontSize": 11,
        "fontStyle": "italic",
        "fill": "#2c3e50",
        "clip": false,
        "font": "Source Sans 3"
      },
      "encoding": {
        "x": {
          "field": "age_value",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              80
            ],
            "nice": false
          }
        },
        "y": {
          "field": "signed_density",
          "type": "quantitative",
          "scale": {
            "domain": [
              -45,
              45
            ],
            "nice": false
          }
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "resolve": {
    "scale": {
      "x": "shared",
      "y": "shared"
    },
    "legend": {
      "color": "shared"
    }
  }
}
