{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Shark Incidents by State: Volume vs Danger",
    "subtitle": "NSW leads in raw numbers, but QLD and SA have the highest fatality rates.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "params": [
    {
      "name": "metric",
      "value": "total",
      "bind": {
        "input": "radio",
        "options": ["total", "fatal_rate"],
        "labels": ["Total incidents", "Fatality rate (%)"],
        "name": "Show: "
      }
    }
  ],
  "width": 700,
  "height": 600,
  "projection": {
    "type": "mercator",
    "center": [133, -27],
    "scale": 850
  },
  "layer": [
    {
      "data": {
        "url": "data/australia_states.json",
        "format": {
          "type": "topojson",
          "feature": "australia_states"
        }
      },
      "transform": [
        {
          "calculate": "slice(datum.properties.iso_3166_2, 3)",
          "as": "state_abbrev"
        },
        {
          "lookup": "state_abbrev",
          "from": {
            "data": { "url": "data/state_choropleth.csv" },
            "key": "State",
            "fields": ["total", "fatal", "fatal_rate"]
          }
        },
        {
          "calculate": "metric === 'total' ? datum.total : datum.fatal_rate",
          "as": "display_value"
        },
        {
          "calculate": "metric === 'total' ? datum.total + ' incidents' : datum.fatal_rate + '% fatal'",
          "as": "value_label"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      },
      "encoding": {
        "color": {
          "field": "display_value",
          "type": "quantitative",
          "scale": {
            "scheme": {
              "expr": "metric === 'total' ? 'blues' : 'orangered'"
            },
            "zero": true
          },
          "legend": {
            "title": {
              "expr": "metric === 'total' ? 'Total incidents' : 'Fatal rate (%)'"
            },
            "orient": "bottom-left",
            "gradientLength": 180,
            "labelFontSize": 11
          },
          "condition": {
            "test": "datum.display_value === null",
            "value": "#d0d0d0"
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "total",
            "type": "quantitative",
            "title": "Total incidents"
          },
          {
            "field": "fatal",
            "type": "quantitative",
            "title": "Fatal"
          },
          {
            "field": "fatal_rate",
            "type": "quantitative",
            "title": "Fatal rate (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "state": "NSW", "lat": -32.4751, "lon": 146.781, "label": "NSW" },
          { "state": "QLD", "lat": -23.1364, "lon": 144.778, "label": "QLD" },
          { "state": "WA", "lat": -25.8483, "lon": 121.646, "label": "WA" },
          { "state": "SA", "lat": -29.6504, "lon": 135.783, "label": "SA" },
          { "state": "VIC", "lat": -37.0082, "lon": 144.75, "label": "VIC" },
          { "state": "TAS", "lat": -42.1383, "lon": 146.603, "label": "TAS" },
          { "state": "NT", "lat": -20.1026, "lon": 133.78, "label": "NT" }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#ffffff",
        "dy": 0
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "text": { "field": "label", "type": "nominal" }
      }
    }
  ]
}
