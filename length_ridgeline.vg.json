{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1000,
  "height": 380,
  "padding": { "top": 24, "left": 4, "right": 12, "bottom": 12 },
  "data": { "url": "data/wrangled_data/length_beeswarm.csv" },
  "config": {
    "view": { "stroke": "transparent", "clip": false },
    "axis": { "labelFont": "Source Sans 3", "titleFont": "Source Sans 3" },
    "legend": { "labelFont": "Source Sans 3", "titleFont": "Source Sans 3" }
  },
  "params": [
    {
      "name": "species_filter",
      "value": null,
      "bind": {
        "input": "select",
        "options": [
          null,
          "White Shark",
          "Tiger Shark",
          "Bull Shark",
          "Wobbegong",
          "Whaler Shark",
          "Bronze Whaler",
          "Other"
        ],
        "labels": [
          "All species",
          "White Shark",
          "Tiger Shark",
          "Bull Shark",
          "Wobbegong",
          "Whaler Shark",
          "Bronze Whaler",
          "Other / unknown"
        ],
        "name": "Filter by species: "
      }
    }
  ],
  "transform": [
    { "calculate": "datum['Shark.length.m']", "as": "length_m" },
    { "calculate": "datum['Victim.injury']", "as": "outcome" },
    { "calculate": "datum['Species.clean']", "as": "species" },
    { "calculate": "datum['Incident.year']", "as": "year" },
    {
      "filter": "!species_filter || datum.species == species_filter"
    }
  ],
  "facet": {
    "row": {
      "field": "outcome",
      "type": "nominal",
      "sort": ["fatal", "injured", "uninjured"],
      "header": {
        "title": null,
        "labelExpr": "datum.value == 'fatal' ? 'Fatal' : datum.value == 'injured' ? 'Injured' : 'Uninjured'",
        "labelFontSize": 12,
        "labelFontWeight": "bold",
        "labelColor": "#1a2530",
        "labelAngle": 0,
        "labelAlign": "right",
        "labelPadding": 8
      }
    }
  },
  "spec": {
    "width": 920,
    "height": 88,
    "transform": [
      {
        "density": "length_m",
        "extent": [0, 7],
        "steps": 180,
        "bandwidth": 0.35,
        "counts": true,
        "as": ["length_value", "density"]
      }
    ],
    "layer": [
      {
        "description": "Average adult height reference at 1.7 m",
        "mark": {
          "type": "rule",
          "stroke": "#1a4a63",
          "strokeWidth": 1,
          "strokeDash": [5, 4],
          "opacity": 0.5
        },
        "encoding": {
          "x": { "datum": 1.7 }
        }
      },
      {
        "description": "Threshold where fatalities first appear",
        "mark": {
          "type": "rule",
          "stroke": "#c0392b",
          "strokeWidth": 1.2,
          "strokeDash": [3, 3],
          "opacity": 0.65
        },
        "encoding": {
          "x": { "datum": 2.0 }
        }
      },
      {
        "description": "Kernel density of incident lengths within each outcome row",
        "mark": {
          "type": "area",
          "opacity": 0.72,
          "line": { "strokeWidth": 1.4, "color": "#ffffff" },
          "interpolate": "monotone"
        },
        "encoding": {
          "x": {
            "field": "length_value",
            "type": "quantitative",
            "scale": { "domain": [0, 7], "nice": false },
            "axis": {
              "title": "Shark length (m)",
              "grid": true,
              "gridColor": "#eeeeee",
              "values": [0, 1, 2, 3, 4, 5, 6, 7]
            }
          },
          "y": {
            "field": "density",
            "type": "quantitative",
            "scale": { "nice": true },
            "axis": null
          },
          "color": {
            "field": "outcome",
            "type": "nominal",
            "scale": {
              "domain": ["fatal", "injured", "uninjured"],
              "range": ["#c0392b", "#e67e22", "#7f8c8d"]
            },
            "legend": {
              "title": "Outcome",
              "orient": "bottom",
              "direction": "horizontal",
              "offset": 4,
              "labelFontSize": 11,
              "labelExpr": "datum.label == 'fatal' ? 'Fatal' : datum.label == 'injured' ? 'Injured' : 'Uninjured'"
            }
          },
          "tooltip": [
            {
              "field": "length_value",
              "type": "quantitative",
              "title": "Length (m)",
              "format": ".1f"
            },
            {
              "field": "density",
              "type": "quantitative",
              "title": "Estimated count",
              "format": ".1f"
            },
            { "field": "outcome", "title": "Outcome" }
          ]
        }
      },
      {
        "description": "Reference label left of 1.7 m line (fatal row only)",
        "transform": [{ "filter": "datum.outcome == 'fatal'" }],
        "mark": {
          "type": "text",
          "align": "right",
          "dx": -6,
          "baseline": "top",
          "dy": 4,
          "fontSize": 10,
          "fontWeight": "bold"
        },
        "encoding": {
          "x": { "datum": 1.7 },
          "y": { "datum": 0 },
          "text": { "datum": "Avg height 1.7 m" },
          "color": { "value": "#1a4a63" }
        }
      },
      {
        "transform": [{ "filter": "datum.outcome == 'fatal'" }],
        "mark": {
          "type": "text",
          "align": "left",
          "dx": 6,
          "baseline": "top",
          "dy": 4,
          "fontSize": 10,
          "fontWeight": "bold"
        },
        "encoding": {
          "x": { "datum": 2.0 },
          "y": { "datum": 0 },
          "text": { "datum": "Fatalities from 2 m" },
          "color": { "value": "#c0392b" }
        }
      }
    ]
  },
  "resolve": {
    "scale": { "x": "shared" },
    "legend": { "color": "shared" }
  }
}
