{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Fatality rate per state",
    "anchor": "middle",
    "fontSize": 12,
    "fontWeight": "bold",
    "color": "#1a2530"
  },
  "width": "container",
  "height": 380,
  "autosize": { "type": "pad", "contains": "padding", "resize": true },
  "padding": { "bottom": 4 },
  "config": {
    "view": { "stroke": "transparent" },
    "axis": { "labelFont": "Source Sans 3", "titleFont": "Source Sans 3" },
    "legend": {
      "labelFont": "Source Sans 3",
      "titleFont": "Source Sans 3",
      "orient": "bottom",
      "offset": 4
    }
  },
  "projection": { "type": "mercator" },
  "layer": [
    {
      "description": "States coloured by share of incidents that were fatal",
      "data": {
        "url": "data/topojson/australia_states.json",
        "format": { "type": "topojson", "feature": "australia_states" }
      },
      "transform": [
        {
          "filter": "datum.properties.name !== 'Lord Howe Island' && datum.properties.name !== 'Macquarie Island'"
        },
        { "calculate": "slice(datum.properties.iso_3166_2, 3)", "as": "state_abbrev" },
        {
          "lookup": "state_abbrev",
          "from": {
            "data": { "url": "data/wrangled_data/state_choropleth.csv" },
            "key": "State",
            "fields": ["total", "fatal", "fatal_rate", "population", "rate_per_million"]
          }
        }
      ],
      "mark": { "type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1.2 },
      "encoding": {
        "color": {
          "field": "fatal_rate",
          "type": "quantitative",
          "scale": { "scheme": "reds", "domain": [0, 30] },
          "legend": {
            "title": "Fatality rate (%)",
            "gradientLength": 200,
            "labelFontSize": 10,
            "titleFontSize": 11,
            "titleFontWeight": "bold"
          }
        },
        "tooltip": [
          { "field": "properties.name", "type": "nominal", "title": "State" },
          { "field": "total", "type": "quantitative", "title": "Total incidents", "format": "," },
          { "field": "fatal", "type": "quantitative", "title": "Fatal incidents" },
          { "field": "fatal_rate", "type": "quantitative", "title": "Fatality rate (%)", "format": ".1f" },
          { "field": "rate_per_million", "type": "quantitative", "title": "Incidents per million people", "format": ".1f" }
        ]
      }
    },
    {
      "description": "Combined state labels, one line, smaller type",
      "data": {
        "values": [
          { "lat": -32.0, "lon": 146.5, "label": "NSW (18.0%)" },
          { "lat": -22.5, "lon": 144.5, "label": "QLD (27.0%)" },
          { "lat": -25.0, "lon": 121.5, "label": "WA (16.6%)" },
          { "lat": -29.0, "lon": 135.5, "label": "SA (27.4%)" },
          { "lat": -19.5, "lon": 133.5, "label": "NT (10.5%)" },
          { "lat": -37.0, "lon": 144.75, "label": "VIC (14.3%)" },
          { "lat": -42.0, "lon": 146.6, "label": "TAS (22.2%)" }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 9,
        "fontWeight": "bold",
        "fill": "#1a2530",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "text": { "field": "label", "type": "nominal" }
      }
    }
  ]
}
